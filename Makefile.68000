include common.mk

all: init smolsh

# Remove any builtin targets...
.SUFFIXES:

#	-ffunction-sections \
#	-fdata-sections \


COPTS=-m68000 \
	-g \
	-flto \
	-nostdlib \
	-std=c99 \
	-Os \
	-I_build/headers/include

%.o: %.c
	$(CC) $(COPTS) \
	 -include $(NOLIBCDIR)/nolibc.h \
	 -c -o $@ $<

%.pie.o: %.c
	$(CC) $(COPTS) \
	-include $(NOLIBCDIR)/nolibc.h \
	-fpie \
	-c -o $@ $<

init: init.o
	$(CC) $(COPTS) $^ -o $@

smolsh: smolsh.o
	$(CC) $(COPTS) $^ -o $@

# stop deleting my dbg elf!
.SECONDARY:

#%.elf.dbg: %.pie.o
#	$(BFDLD) \
#		--gc-sections \
#		--print-gc-sections \
#		--no-dynamic-linker \
#		--hash-style=gnu \
#		--undefined=_start_c \
#		-pie $^ -o $@

%.elf.dbg: %.c
	$(CC) $(COPTS) \
	-include $(NOLIBCDIR)/nolibc.h \
	-Wl,--no-dynamic-linker \
	-Wl,--undefined=_relocate \
	-Wl,--hash-style=gnu \
	-Wl,-z,max-page-size=4 \
	-pie \
	-o $@ $<

%.elf: %.elf.dbg
	$(STRIP) $< -o $@

.PHONY: elfs
elfs: init.elf smolsh.elf dmesg.elf ls.elf cat.elf mkdir.elf

.PHONY: clean
clean:
	rm -f init smolsh *.o *.gdb *.elf *.elf.dbg
