include common.mk

all: elfs

#	-ffunction-sections \
#	-fdata-sections \


COPTS += -m68000 \
	 -D R_68K_RELATIVE=22

#	-I_build/headers/include

# stop deleting my dbg elf!
.SECONDARY:

#%.elf.dbg: %.pie.o
#	$(BFDLD) \
#		--gc-sections \
#		--print-gc-sections \
#		--no-dynamic-linker \
#		--hash-style=gnu \
#		--undefined=_start_c \
#		-pie $^ -o $@


#	-Wl,--no-dynamic-linker \

STATICPIE=-fpie -pie -Wl,--no-dynamic-linker

# This reduces the size of the binaries by putting segments
# with different permissions on the same 4K page which you
# might care about if you have an MMU.
COPTS += -Wl,-z,max-page-size=4

%.68000.elf.dbg: %.c $(HEADERS)
	$(CC) $(COPTS) \
	$(STATICPIE) \
	-o $@ $< -lgcc

%.68000.elf: %.68000.elf.dbg
	$(STRIP) $< -o $@

.PHONY: system_elfs user_elfs
SYSTEM_ELFS = $(addsuffix .68000.elf,$(PROGS_SYSTEM))
SYSTEM_ELFS += $(addsuffix .68000.elf,$(PROGS_NET_SYSTEM))
USER_ELFS = $(addsuffix .68000.elf,$(PROGS_USER))
USER_ELFS += $(addsuffix .68000.elf,$(PROGS_NET_USER))

elfs: $(SYSTEM_ELFS) $(USER_ELFS)

.PHONY: m68k.tar
m68k.tar: rootskel elfs
	tar -cf $@ --mode=755 --owner=root:0 --group=root:0 -C rootskel .
	tar -rf $@ --mode=500 --owner=root:0 --group=root:0 --transform 's|^|sbin/|' --transform 's|\.68000\.elf||' $(SYSTEM_ELFS)
	tar -rf $@ --mode=555 --owner=root:0 --group=root:0 --transform 's|^|bin/|' --transform 's|\.68000\.elf||' $(USER_ELFS)

.PHONY: m68k.erofs
m68k.erofs: m68k.tar
	$(EROFS_CMD) $@ $<

.PHONY: clean
clean:
	rm -f *.o *.gdb *.68000.elf *.68000.elf.dbg m68k.tar m68k.erofs
