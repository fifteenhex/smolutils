{
	"defaults": {
		"user": "root",
		"group": "root"
	},
	"root": {
		"entities": {
                	"dev" : {
				"type": "dir"
			},
			"bin" : {
                        	"type": "dir",
				"mode": "0555",
				"defaults": {
					"mode": "0555"
				},
				"entities": {
					"cat": { },
					"cp": { },
					"chmod": { },
					"chown": { },
					"df": { },
					"dmesg": { },
					"smolsh": { },
					"xxd": { },
					"man": { },
					"less": { },
					"uname": { },
					"touch": { },
					"kill": { },
					"ls": { },
					"ps": { },
					"sha256sum": { },
					"resolv": {
						"feature": "net"
					},
					"tftp": {
						"feature": "net"
					},
					"uname": { },
					"ping": {
						"feature": "net",
						"xattrs": {
							"security.capability": "cap_net_raw+ep"
						}
					},
					"mount": { },
					"umount": {
						"type": "symlink",
						"target": "/bin/mount"
					},
					"rmdir": {
						"type": "symlink",
						"target": "/bin/touch"
					},
					"mkdir": {
						"type": "symlink",
						"target": "/bin/touch"
					},
					"ln": {
						"type": "symlink",
						"target": "/bin/touch"
					},
					"rm": {
						"type": "symlink",
						"target": "/bin/touch"
					}
				}
                	},
                	"proc" : {
				"type": "dir"
			},
                	"run" : {
				"type": "dir"
			},
                	"sbin" : {
				"type": "dir",
				"defaults": {
					"mode": "0500"
				},
				"entities": {
					"getty": { },
					"startup": { },
					"sntp": {
						"feature": "net"
					},
					"dhcpc": {
						"feature": "net"
					},
					"init": { }
				}
			},
                	"tmp" : {
				"type": "dir"
			},
                	"sys" : {
				"type": "dir"
			}
		}
	}
}
