include common.mk

STATICPIE=-static-pie

.SECONDARY:
%.x86_64.elf.dbg: %.c
	$(CC) $(COPTS) \
	$(STATICPIE) \
	-D R_AMD64_RELATIVE=8 \
	-o $@ $<

%.x86_64.elf: %.x86_64.elf.dbg
	$(STRIP) $< -o $@

.PHONY: elfs
elfs: $(addsuffix .x86_64.elf,$(PROGS))

.PHONY: clean
clean:
	rm -f *.x86_64.elf *.x86_64.elf.dbg
